# Secrets / credentials — never commit
*.pem
*.p12
*.key
*.pfx
*credentials*
*secret*
.env
.env.*

# OS / editor junk
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# Local media / recordings (keep polished assets/ and UseDemo.mp4 tracked intentionally)
Screen Recording*.mp4
*.local.mp4
*.raw.mp4

# Local-only scratch helpers (packaging scripts are force-tracked below)
scratch/*
!scratch/zip_extension.py
!scratch/generate_brand_assets.py

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Temp / logs
*.tmp
*.temp
*.log
*.bak
*.orig

# Optional local notes
TODO.local.md
NOTES.local.md
